# Public site configuration — NON-SECRET. NEXT_PUBLIC_* values are inlined into
# the client bundle, so never put secrets here. Read via lib/config.js and used
# for metadata, JSON-LD, sitemap, robots, the OG share card and contact buttons.
#
# Override per-environment in Vercel's dashboard if the domain/email changes.

NEXT_PUBLIC_SITE_URL=https://humanoid-robot-solutions.vercel.app
NEXT_PUBLIC_CONTACT_EMAIL=ovezorazberdiyev@gmail.com
