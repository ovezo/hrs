# Public site configuration — NON-SECRET. NEXT_PUBLIC_* values are inlined into
# the client bundle, so never put secrets here. Read via lib/config.js and used
# for metadata, JSON-LD, sitemap, robots, the OG share card and contact buttons.
#
# Override per-environment in Vercel's dashboard if the domain/email changes.

NEXT_PUBLIC_SITE_URL=https://hrsrobot.co.uk

NEXT_PUBLIC_CONTACT_EMAIL=info@hrsrobot.co.uk

# Web3Forms access key for the /contact form. PUBLIC by design — the form submits
# to Web3Forms directly from the browser (their free plan blocks server-side
# calls), so the key is inlined into the client bundle. It only permits sending
# to the inbox configured for this form in the Web3Forms dashboard.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=0767b190-f1e6-40f8-9bdf-4b0467154112
